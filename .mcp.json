{
    "mcpServers": {
        "laravel-boost": {
            "command": "docker",
            "args": [
                "compose",
                "--project-directory",
                "/root/Downloora",
                "exec",
                "-T",
                "-e",
                "APP_ENV=local",
                "app",
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    }
}
